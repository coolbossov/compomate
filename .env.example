# Copy to .env.local and fill in real values.
# NEVER commit .env.local — this file only contains placeholders.

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL is used client-side; SUPABASE_URL is the server alias.
# Both are accepted — set whichever your Supabase project uses.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# ---------------------------------------------------------------------------
# Cloudflare R2
# ---------------------------------------------------------------------------
# Optional but recommended for subject/backdrop/export asset storage.
# Create S3-compatible credentials in Cloudflare R2 and set the endpoint to:
# https://<account-id>.r2.cloudflarestorage.com

R2_ACCOUNT_ID=<cloudflare-account-id>
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET_NAME=compomate-uploads
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# ---------------------------------------------------------------------------
# AI providers
# ---------------------------------------------------------------------------

FAL_KEY=<fal-ai-key>
GEMINI_API_KEY=<google-gemini-key>

# ---------------------------------------------------------------------------
# Observability (all optional — app runs without these)
# ---------------------------------------------------------------------------

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=/ingest

NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
